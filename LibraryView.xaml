<Window x:Class="MyApp.LibraryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyApp"
        mc:Ignorable="d"
        Background="#F0F2F5"
        Title="LibraryView" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,20">
            <TextBlock 
                Text="Exercise Library"
                FontSize="28"
                FontWeight="Bold"
                Foreground="#333"
                HorizontalAlignment="Center"/>
            <TextBox
                x:Name="SearchBox"
                Margin="0,5,0,0"
                Height="35"
                VerticalAlignment="Center"
                Padding="10,0"
                Tag="Serch exercises..."
                TextChanged="SearchBox_TextChanged"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Margin="10"
                Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="NewExerciseName"
                         Grid.Column="0"
                         Margin="5"
                         Tag="New exercise name"/>
                <ComboBox x:Name="NewExerciseCategory"
                          Grid.Column="1"
                          Margin="5"
                          VerticalAlignment="Center">
                    <ComboBoxItem Content="Chest workout" IsSelected="True"/>
                    <ComboBoxItem Content="Back Workout"/>
                    <ComboBoxItem Content="Leg workout"/>
                    <ComboBoxItem Content="Arm workout"/>
                    <ComboBoxItem Content="Shoulder workout"/>
                    <ComboBoxItem Content="Cardio workout"/>
                </ComboBox>

                <Button Grid.Column="2"
                        Content="Add"
                        Click="AddLibraryExercise_Click"
                        Background="#4A90E2"
                        Foreground="White"
                        Margin="5"
                        FontWeight="Bold"/>
            </Grid>
        </Border>

        <ScrollViewer
            Grid.Row="2"
            VerticalScrollBarVisibility="Auto">
            <ItemsControl
                x:Name="LibraryItemsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Background="White"
                            Margin="0,2"
                            Padding="10"
                            CornerRadius="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Text="{Binding BindingGroupName, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontWeight="SemiBold"/>
                                
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Category}"
                                           Foreground="Gray"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>

                                <Button Grid.Column="2"
                                        Content="&#xE74D;"
                                        FontFamily="Segoe MDL2 Assets"
                                        Background="Transparent"
                                        Foreground="#FF5252"
                                        BorderThickness="0"
                                        Click="DeleteLibraryExercise_Click"
                                        Tag="{Binding}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
