<UserControl x:Class="MyApp.TrainDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MyApp"
             mc:Ignorable="d" 
             Background="#F0F2F5"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid
        Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <StackPanel 
            Grid.Row="0"
            Margin="0,0,0,20">
            <TextBlock
                Text="{Binding Type}"
                FontSize="28"
                FontWeight="Bold"
                Foreground="#333"/>
            
            <StackPanel
                Orientation="Horizontal"
                Margin="0,5,0,0">
                    <TextBlock
                        Text="{Binding Date}"
                        FontSize="16"
                        Foreground="Gray"
                        Margin="0,0,15,0"/>

                    <TextBlock
                        Text="&#xE823;"
                        FontFamily="Segoe MDL2 Assets"
                        VerticalAlignment="Center"
                        Foreground="Gray"
                        Margin="0,0,5,0"/>

                    <TextBlock
                        Text="{Binding Duration}"
                        FontSize="16"
                        Foreground="Gray"/>
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ExercisesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Background="White"
                            CornerRadius="15"
                            Margin="0,0,0,15"
                            Padding="15">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="10"
                                    Opacity="0.05"
                                    ShadowDepth="2"/>
                            </Border.Effect>

                            <StackPanel>
                                <TextBlock
                                    Text="{Binding Name}"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    Foreground="#4A90E2"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="2"
                Content="+ Add Exercises"
                Height="45"
                Background="#4A90E2"
                Foreground="White"
                FontSize="16"
                FontWeight="Bold"
                Cursor="Hand"
                Margin="0,10,0,0"
                BorderThickness="0">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="10"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</UserControl>
