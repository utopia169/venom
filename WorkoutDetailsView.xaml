<UserControl x:Class="MyApp.TrainDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MyApp"
             mc:Ignorable="d" 
             Background="#F0F2F5"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid
        Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <StackPanel 
            Grid.Row="0"
            Margin="0,0,0,20">
            <TextBlock
                Text="{Binding Type}"
                FontSize="28"
                FontWeight="Bold"
                Foreground="#333"/>
            
            <StackPanel
                Orientation="Horizontal"
                Margin="0,5,0,0">
                    <TextBlock
                        Text="{Binding Date}"
                        FontSize="16"
                        Foreground="Gray"
                        Margin="0,0,15,0"/>

                    <TextBlock
                        Text="&#xE823;"
                        FontFamily="Segoe MDL2 Assets"
                        VerticalAlignment="Center"
                        Foreground="Gray"
                        Margin="0,0,5,0"/>

                    <TextBlock
                        Text="{Binding Duration}"
                        FontSize="16"
                        Foreground="Gray"/>
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ExercisesList"
                          ItemsSource="{Binding Exercises}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Background="White"
                            CornerRadius="15"
                            Margin="0,0,0,15"
                            Padding="20">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="10"
                                    Opacity="0.05"
                                    ShadowDepth="2"/>
                            </Border.Effect>

                            <StackPanel>
                                <TextBlock
                                    Text="{Binding Name}"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    Foreground="#4A90E2"
                                    Margin="0,0,0,15"/>

                                <Grid 
                                    Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Text="Weight (kg)"
                                        Foreground="Gray"
                                        FontSize="12"/>
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="Reps"
                                        Foreground="Gray"
                                        FontSize="12"/>
                                </Grid>

                                <ItemsControl
                                    ItemsSource="{Binding SetItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="40"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBox
                                                    Grid.Column="0"
                                                    Margin="0,0,5,0"
                                                    Padding="5"
                                                    Text="{Binding Weight, UpdateSourceTrigger=PropertyChanged}"
                                                    Background="#F8FAFC"
                                                    BorderBrush="#E2E8F0"/>

                                                <TextBox 
                                                    Grid.Column="1"
                                                    Margin="5,0,5,0"
                                                    Padding="5"
                                                    Text="{Binding Reps, UpdateSourceTrigger=PropertyChanged}"
                                                    Background="#F8FAFC"
                                                    Foreground="#333"/>

                                                <Button 
                                                    Grid.Column="2"
                                                    Content=""
                                                    FontFamily="Segoe MDL2 Assets"
                                                    Background="Transparent"
                                                    Foreground="#FF5252"
                                                    BorderThickness="0"
                                                    FontSize="14"
                                                    Click="RemoveSet_Click"
                                                    Tag="{Binding}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button 
                                    Content="+ Add Set"
                                    HorizontalAlignment="Left"
                                    Background="#4A90E2"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Padding="8,4"
                                    FontWeight="SemiBold"
                                    Margin="0,10,0,0"
                                    Cursor="Hand"
                                    Click="AddSet_Click"
                                    Tag="{Binding}">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <Rectangle 
                                    Height="1"
                                    Fill="#F0F2F5"
                                    Margin="0,15,0,10"/>

                                <StackPanel
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                                    
                                    <TextBlock
                                        Text="Avg. Weight: "
                                        Foreground="Gray"
                                        VerticalAlignment="Center"/>

                                    <TextBlock
                                        Text="{Binding AverageWeight, StringFormat={}{0:F1} kg}"
                                        FontWeight="Bold"
                                        Foreground="#4A90E2"
                                        Margin="0,0,15,0"/>

                                    <TextBlock
                                        Text="Avg. Reps: "
                                        Foreground="Gray"
                                        VerticalAlignment="Center"/>

                                    <TextBlock
                                        Text="{Binding AverageReps, StringFormat={}{0:F1}}"
                                        FontWeight="Bold"
                                        Foreground="#4A90E2"/>
                                    
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="2"
                Content="+ Add Exercises"
                x:Name="AddExerciseBtn"
                Click="AddExerciseBtn_Click"
                Height="45"
                Background="#4A90E2"
                Foreground="White"
                FontSize="16"
                FontWeight="Bold"
                Cursor="Hand"
                Margin="0,10,0,0"
                BorderThickness="0">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="10"/>
                </Style>
            </Button.Resources>
        </Button>


        <Popup
            x:Name="ExercisePopup"
            PlacementTarget="{Binding ElementName=AddExerciseBtn }"
            Placement="Top"
            StaysOpen="False"
            AllowsTransparency="True">
            <Border Width="250"
                    MaxHeight="300"
                    Background="White"
                    BorderBrush="#E4E7EB"
                    BorderThickness="1"
                    CornerRadius="10"
                    Margin="10"
                    Padding="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15"
                                      ShadowDepth="3"
                                      Opacity="0.1"
                                      Color="Black"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Selected Exercise"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#333"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                    <ListBox x:Name="ExerciseListBox"
                             BorderThickness="0"
                             Foreground="Transparent"
                             SelectionChanged="ExercisesListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontSize="14"
                                           Padding="5,8"
                                           Cursor="Hand"
                                           Foreground="#333"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
